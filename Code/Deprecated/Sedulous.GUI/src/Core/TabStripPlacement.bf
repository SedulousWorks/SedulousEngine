namespace Sedulous.GUI;

/// Specifies where the tab strip is positioned relative to the content area.
public enum TabStripPlacement
{
	/// Tabs are positioned at the top (default).
	Top,
	/// Tabs are positioned at the bottom.
	Bottom,
	/// Tabs are positioned on the left side.
	Left,
	/// Tabs are positioned on the right side.
	Right
}
